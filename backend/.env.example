# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# Encryption key for credential store (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-key-here

# Docker
DOCKER_NETWORK=openclaw-agents
OPENCLAW_AGENT_IMAGE=openclaw/agent:latest

# LLM
LLM_API_KEY=your-llm-api-key

# Platform
PLATFORM_HOST=0.0.0.0
PLATFORM_PORT=8000
PLATFORM_GATEWAY_URL=http://host.docker.internal:8000/gateway
